{
  "rules": {
    ".read": false,
    ".write": false,

    "events": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "bookings": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'partner')",
      "$bookingId": {
        ".read": "auth != null && (data.child('userId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'partner')",
        ".write": "auth != null"
      }
    },

    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "streams": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'customer'"
    },

    "assignments": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "locked": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "daily": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'customer'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'customer'"
    },

    "leads": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'customer'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'customer'"
    },

    "pipeline": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'customer'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'customer'"
    },

    "checklist": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'customer'"
    },

    "collaborators": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'customer'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'customer'"
    },

    "miscStreams": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'customer'"
    },

    "feedback": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "finance": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    }
  }
}
